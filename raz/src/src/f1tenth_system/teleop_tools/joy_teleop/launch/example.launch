<launch>
  <arg name="racecar_version" />
  <arg name="joy_teleop_config"
       default="$(find joy_teleop)/config//joy_teleop.yaml" />

  <rosparam file="$(arg joy_teleop_config)" command="load" />

  <!-- <node pkg="joy" type="joy_node" name="joy_node" /> -->

  <node pkg="joy_teleop" type="joy_teleop.py" name="joy_teleop" />

  <group ns="torso_controller">
    <node pkg="joy_teleop" type="incrementer_server.py" name="incrementer"/>
  </group>

</launch>
