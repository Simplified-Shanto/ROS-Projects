<?xml version="1.0"?>
<robot name="im10a_dummy">
  <link name="imu_link"/>

  <link name="imu_body">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.055 0.036 0.012"/>
      </geometry>
      <material name="blue">
        <color rgba="0.1 0.4 0.9 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="imu_link_to_body" type="fixed">
    <parent link="imu_link"/>
    <child link="imu_body"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
</robot>
